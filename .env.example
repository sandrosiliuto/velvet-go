# Copia este archivo como ".env.local" y rellena los valores reales
# NUNCA commitees .env.local

# Supabase > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Supabase > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Supabase > Project Settings > API > service_role (SECRETO - solo servidor)
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Contraseña para el panel /admin
ADMIN_PASSWORD=tu_contraseña_secreta_aqui

# URL del sitio (para el redirect de logout en producción)
NEXT_PUBLIC_SITE_URL=https://tu-proyecto.vercel.app
